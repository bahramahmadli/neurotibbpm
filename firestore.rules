rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Check if user is a member of the project
    function isMember(projectId) {
      return isAuth() && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }

    // Get the user's member document
    function getMember(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }

    // Check the user's role in the project
    function getRole(projectId) {
      return getMember(projectId).data.role;
    }

    function hasValidRole() {
      return request.resource.data.role in ['owner', 'editor', 'viewer'];
    }

    function isSelfMemberCreate(projectId, userId) {
      return isSelf(userId)
        && !exists(/databases/$(database)/documents/projects/$(projectId)/members/$(userId))
        && hasValidRole()
        && (
          (!exists(/databases/$(database)/documents/projects/$(projectId)) && request.resource.data.role == 'owner') ||
          (exists(/databases/$(database)/documents/projects/$(projectId)) && request.resource.data.role == 'editor')
        );
    }

    // Scoped rules under projects/{projectId}
    match /projects/{projectId} {
      
      // Project metadata: members can read; owners can write
      allow get: if isAuth();
      allow list: if isMember(projectId);
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isMember(projectId) && getRole(projectId) == 'owner';

      // Members subcollection
      match /members/{userId} {
        allow get: if isMember(projectId) || isSelf(userId);
        allow list: if isMember(projectId);
        
        // Allow users to provision their own project membership after Firebase Auth succeeds.
        // Existing owners can still add members explicitly.
        allow create: if isAuth() && (
          isSelfMemberCreate(projectId, userId) ||
          (exists(/databases/$(database)/documents/projects/$(projectId)) && isMember(projectId) && getRole(projectId) == 'owner')
        );
        
        // Owners can manage members roles
        allow update: if isMember(projectId) && getRole(projectId) == 'owner' 
          && request.resource.data.role in ['owner', 'editor', 'viewer'];
          
        // Owners can delete other members
        allow delete: if isMember(projectId) && getRole(projectId) == 'owner' && userId != request.auth.uid;
      }

      // Owner bootstrap and migration metadata.
      match /settings/{settingId} {
        allow read: if isMember(projectId);
        allow write: if isMember(projectId) && getRole(projectId) in ['owner', 'editor'];
      }

      // Platforms subcollection
      match /platforms/{platformId} {
        allow read: if isMember(projectId);
        allow write: if isMember(projectId) && getRole(projectId) in ['owner', 'editor'];
      }

      // Phases subcollection
      match /phases/{phaseId} {
        allow read: if isMember(projectId);
        allow write: if isMember(projectId) && getRole(projectId) in ['owner', 'editor'];
      }

      // Items subcollection
      match /items/{itemId} {
        allow read: if isMember(projectId);
        allow write: if isMember(projectId) && getRole(projectId) in ['owner', 'editor']
          && request.resource.data.type in ['page', 'ai', 'feature']
          && request.resource.data.title.size() > 0
          && request.resource.data.platformId != null
          && request.resource.data.phaseId != null;
      }

      // Audit logs subcollection (Create only, no read/write modifications allowed)
      match /auditLogs/{logId} {
        allow read: if isMember(projectId);
        allow create: if isMember(projectId) && getRole(projectId) in ['owner', 'editor'];
        allow update, delete: if false;
      }
    }
  }
}
